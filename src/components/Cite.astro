---
import { getEntry } from 'astro:content';

interface Props {
  id: string; // Can be a single id "key1" or multiple comma-separated ids "key1, key2"
}

const { id } = Astro.props;

// 1. Split the incoming ids string into a clean array of lowercase keys
const targetIds = id.split(',').map(item => item.trim().toLowerCase());

const currentUrl = Astro.url.pathname;
let referencesArray: any[] = [];

// 2. Fetch the current abstract entry from the content layer to read its global reference order
const slug = currentUrl.split('/abstracts/')[1]?.replace(/\/$/, '');
if (slug) {
  const docEntry = await getEntry('docs', `abstracts/${slug}`);
  if (docEntry?.data?.references) {
    referencesArray = docEntry.data.references;
  }
}

// 3. Map our target keys to their actual 1-based index positions
const indices: number[] = targetIds
  .map(targetId => {
    const idx = referencesArray.findIndex((ref: any) => {
      const refKey = typeof ref === 'object' && ref !== null ? ref.id : ref;
      return refKey?.toLowerCase() === targetId;
    });
    return idx !== -1 ? idx + 1 : null;
  })
  .filter((num): num is number => num !== null)
  .sort((a, b) => a - b); // Keep numbers sorted sequentially

// 4. Compress consecutive indices into ranges (e.g., [1, 2, 3, 5] -> "1-3, 5")
function formatRanges(nums: number[]): string {
  if (nums.length === 0) return '?';
  
  const result: string[] = [];
  let start = nums[0];
  let end = nums[0];

  for (let i = 1; i <= nums.length; i++) {
    // If consecutive, extend the range end
    if (i < nums.length && nums[i] === end + 1) {
      end = nums[i];
    } else {
      // Range complete: compress if it spans 3 or more elements
      if (end - start >= 2) {
        result.push(`${start}-${end}`);
      } else if (end !== start) {
        // Just two items, join with a comma (e.g., "1,2")
        result.push(`${start}, ${end}`);
      } else {
        result.push(`${start}`);
      }
      
      if (i < nums.length) {
        start = nums[i];
        end = nums[i];
      }
    }
  }
  return result.join(', ');
}

const displayString = formatRanges(indices);
// For the anchor link, link to the first ID in the multiple sequence
const primaryAnchor = targetIds[0] || '';
---

<a href={`#ref-${primaryAnchor}`} class="inline-citation" title={`Jump to reference section`}>[{displayString}]</a>

<style>
  .inline-citation {
    color: var(--sl-color-text-accent);
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.15s ease;
  }
  .inline-citation:hover {
    text-decoration: underline;
    transform: translateY(-1px);
  }
</style>