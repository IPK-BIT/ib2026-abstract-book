	month = sep,
	year = {2024},
	keywords = {Archives, Computer software, Galaxies, Language, Metadata, Reproducibility, Software tools, Web-based applications},
	pages = {e0309210},
	file = {Full Text PDF:C\:\\Users\\feser\\Zotero\\storage\\HAVS2GCA\\Leo et al. - 2024 - Recording provenance of workflow runs with RO-Crate.pdf:application/pdf},
