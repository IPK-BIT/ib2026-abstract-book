	keywords = {Machine learning, Computational biophysics, Protein structure predictions, Structural biology},
	pages = {583--589},
	file = {Full Text PDF:C\:\\Users\\feser\\Zotero\\storage\\FYG6PLF3\\Jumper et al. - 2021 - Highly accurate protein structure prediction with AlphaFold.pdf:application/pdf},
