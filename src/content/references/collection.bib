@article{arend_-premise_2020,
	title = {The on-premise data sharing infrastructure e!{DAL}: {Foster} {FAIR} data for faster data acquisition},
	volume = {9},
	issn = {2047-217X},
	shorttitle = {The on-premise data sharing infrastructure e!{DAL}},
	url = {https://doi.org/10.1093/gigascience/giaa107},
	doi = {10.1093/gigascience/giaa107},
	abstract = {The FAIR data principle as a commitment to support long-term research data management is widely accepted in the scientific community. Although the ELIXIR Core Data Resources and other established infrastructures provide comprehensive and long-term stable services and platforms for FAIR data management, a large quantity of research data is still hidden or at risk of getting lost. Currently, high-throughput plant genomics and phenomics technologies are producing research data in abundance, the storage of which is not covered by established core databases. This concerns the data volume, e.g., time series of images or high-resolution hyper-spectral data; the quality of data formatting and annotation, e.g., with regard to structure and annotation specifications of core databases; uncovered data domains; or organizational constraints prohibiting primary data storage outside institional boundaries.To share these potentially dark data in a FAIR way and master these challenges the ELIXIR Germany/de.NBI service Plant Genomic and Phenomics Research Data Repository (PGP) implements a “bring the infrastructure to the data” approach, which allows research data to be kept in place and wrapped in a FAIR-aware software infrastructure. This article presents new features of the e!DAL infrastructure software and the PGP repository as a best practice on how to easily set up FAIR-compliant and intuitive research data services. Furthermore, the integration of the ELIXIR Authentication and Authorization Infrastructure (AAI) and data discovery services are introduced as means to lower technical barriers and to increase the visibility of research data.The e!DAL software matured to a powerful and FAIR-compliant infrastructure, while keeping the focus on flexible setup and integration into existing infrastructures and into the daily research process.},
	number = {10},
	urldate = {2026-07-08},
	journal = {GigaScience},
	author = {Arend, Daniel and König, Patrick and Junker, Astrid and Scholz, Uwe and Lange, Matthias},
	month = oct,
	year = {2020},
	pages = {giaa107},
	file = {Full Text PDF:C\:\\Users\\feser\\Zotero\\storage\\92SQVM5M\\Arend et al. - 2020 - The on-premise data sharing infrastructure e!DAL Foster FAIR data for faster data acquisition.pdf:application/pdf;Snapshot:C\:\\Users\\feser\\Zotero\\storage\\J2MJIRMT\\giaa107.html:text/html},
}

@article{barysch_position_2025,
	title = {Position paper on cooperation between {NFDI} and de.{NBI} \& {ELIXIR}-{DE}},
	url = {https://zenodo.org/records/17767574},
	doi = {10.5281/zenodo.17767574},
	abstract = {Summary

de.NBI \& ELIXIR-DE are central pillars of the German research data infrastructure and, with the de.NBI cloud, offer cloud-based services, storage solutions, and resources for scientific research and education. They support scientific work with computing power, data management, and security, especially for sensitive data such as human genome data. However, they face challenges: Long-term financing of hardware and personnel is crucial to meet the associated, ever-growing demands. In addition, there is a lack of needs-based services, including for long-term data archiving, which will have to be coordinated in the future with other infrastructures such as the National High Performance Computing Network (NHR) and other actors, e.g., within the European Open Science Cloud (EOSC). The increasing demand for powerful GPUs for AI and HPC requires continuous investment, often at the expense of renewing existing systems. At the same time, the development of secure working environments (SPE/TRE) is necessary to comply with EU and national guidelines and to protect sensitive data.

Cooperation with the National Research Data Infrastructure (NFDI) and the National High Performance Computing Network is crucial: The de.NBI Cloud is closely linked to the NFDI consortia and has been supporting them in the development and operation of sustainable research data infrastructures from the very beginning. The NHR provides the NFDI consortia with HPC infrastructures for use in AI, HPC, and data applications. Closer cooperation between NFDI, NHR, and de.NBI Cloud would not only improve the integration of technologies in the transition area between cloud, HPC, and AI, but also offer a sustainable and needs-based option for integrated research data management, even across disciplines.

Strategically, de.NBI \& ELIXIR-DE with the de.NBI Cloud are key players within the EOSC Federation and for the national EOSC node in Germany. Their further development requires sustainable funding, technological adaptation, and close cooperation with NFDI, NHR, and European initiatives to ensure Germany's research competitiveness and independence. Only in this way can research continue to work with state-of-the-art technology and under secure conditions in the long term.},
	language = {deu},
	urldate = {2026-07-08},
	publisher = {Zenodo},
	author = {Barysch, Sina and Buchhalter, Ivo and Dammann-Kalinowski, Tanja and Goesmann, Alexander and Grüning, Björn and Jünemann, Sebastian and Krüger, Jens and Kummer, Ursula and Lawerenz, Chris and Sczyrba, Alexander and Wagener, Harald and Hoffmann, Nils and Kohlbacher, Oliver and de.NBI, German Network for Bioinformatics Infrastructure-},
	month = nov,
	year = {2025},
	keywords = {ELIXIR, NFDI, de.NBI, ELIXIR-DE, EOSC, research infrastructure, cloud, de.NBI Cloud, NHR, research data infrastructure},
	file = {Full Text PDF:C\:\\Users\\feser\\Zotero\\storage\\2FI8KF6V\\Barysch et al. - 2025 - Position paper on cooperation between NFDI and de.NBI & ELIXIR-DE.pdf:application/pdf},
}

@article{kanza_electronic_2017,
	title = {Electronic lab notebooks: can they replace paper?},
	volume = {9},
	issn = {1758-2946},
	shorttitle = {Electronic lab notebooks},
	url = {https://doi.org/10.1186/s13321-017-0221-3},
	doi = {10.1186/s13321-017-0221-3},
	abstract = {Despite the increasingly digital nature of society there are some areas of research that remain firmly rooted in the past; in this case the laboratory notebook, the last remaining paper component of an experiment. Countless electronic laboratory notebooks (ELNs) have been created in an attempt to digitise record keeping processes in the lab, but none of them have become a ‘key player’ in the ELN market, due to the many adoption barriers that have been identified in previous research and further explored in the user studies presented here. The main issues identified are the cost of the current available ELNs, their ease of use (or lack of it) and their accessibility issues across different devices and operating systems. Evidence suggests that whilst scientists willingly make use of generic notebooking software, spreadsheets and other general office and scientific tools to aid their work, current ELNs are lacking in the required functionality to meet the needs of the researchers. In this paper we present our extensive research and user study results to propose an ELN built upon a pre-existing cloud notebook platform that makes use of accessible popular scientific software and semantic web technologies to help overcome the identified barriers to adoption.},
	language = {en},
	number = {1},
	urldate = {2026-07-08},
	journal = {Journal of Cheminformatics},
	author = {Kanza, Samantha and Willoughby, Cerys and Gibbins, Nicholas and Whitby, Richard and Frey, Jeremy Graham and Erjavec, Jana and Zupančič, Klemen and Hren, Matjaž and Kovač, Katarina},
	month = may,
	year = {2017},
	keywords = {Cloud, Semantic web, Electronic lab notebooks (ELNs), Notebooking software, Scientific software},
	pages = {31},
	file = {Full Text PDF:C\:\\Users\\feser\\Zotero\\storage\\QHXDJ2XV\\Kanza et al. - 2017 - Electronic lab notebooks can they replace paper.pdf:application/pdf},
}

